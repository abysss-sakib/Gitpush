# GITPUSH environment variables
# Copy to .env for local development (do NOT commit .env)

# Required: GitHub personal access token with `repo` scope.
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_replace_with_your_token

# Optional: default GitHub user shown on first load (can be changed in the UI).
GITPUSH_DEFAULT_USERNAME=abysss-sakib

# Optional: where the persisted {username, repo} context is stored.
# Defaults to ./.gitpush_ctx.json next to app.py.
# GITPUSH_CONTEXT_PATH=/var/data/gitpush_ctx.json

# Optional: Flask session secret (generated automatically on Render).
SECRET_KEY=change-me-locally

# Optional: enable Flask debug locally.
FLASK_DEBUG=0
