# ─────────────────────────────────────────────────────────────────────────────
# GITPUSH · Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Copy this file → rename to ".env"  (in the same folder as app.py)
# 2. Fill in your real values below
# 3. NEVER commit .env to GitHub (it is already in .gitignore)
#
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub Personal Access Token (REQUIRED) ───────────────────────────────
#
# Generate at: https://github.com/settings/tokens
# → "Generate new token (classic)"
# → Scopes to tick:  ✅ repo  (full control of private repositories)
#
# Paste your token below (starts with ghp_ or github_pat_):
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ── Flask secret key (optional, auto-generated if blank) ──────────────────
SECRET_KEY=change-me-to-any-random-string

# ── Port (optional, default 5000) ─────────────────────────────────────────
PORT=5000
