# ============================================================
# GITPUSH · dev.sakib — Environment Variables
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values below
# 3. NEVER commit .env to GitHub — it contains your token
# ============================================================

# ----------------------------------------------------------
# REQUIRED — GitHub Personal Access Token
# ----------------------------------------------------------
# How to create one:
#   1. Go to: https://github.com/settings/tokens/new
#   2. Name: gitpush
#   3. Expiration: 90 days (or "No expiration")
#   4. Scopes: check repo (full repository read/write access)
#   5. Click Generate token — copy it immediately (shown once)
#
# WARNING: Anyone with this token can read/write ALL your
# repositories. Treat it like a password.
# ----------------------------------------------------------
GITHUB_TOKEN=ghp_replace_with_your_actual_token_here

# ----------------------------------------------------------
# OPTIONAL — Default GitHub Username
# ----------------------------------------------------------
# Pre-fills the username shown in the UI on first load.
# You can always change it via the "Change User" button.
# ----------------------------------------------------------
GITPUSH_DEFAULT_USERNAME=your_github_username

# ----------------------------------------------------------
# OPTIONAL — Context Storage Path
# ----------------------------------------------------------
# Where active {username, repo} is persisted between requests.
# Defaults to .gitpush_ctx.json next to app.py.
# On Render with persistent disk, use:
#   GITPUSH_CONTEXT_PATH=/var/data/gitpush_ctx.json
# ----------------------------------------------------------
# GITPUSH_CONTEXT_PATH=/var/data/gitpush_ctx.json

# ----------------------------------------------------------
# OPTIONAL — Flask Session Secret Key
# ----------------------------------------------------------
# Used to sign session cookies. Change to any random string.
# Render auto-generates this value for you via render.yaml.
# ----------------------------------------------------------
SECRET_KEY=change-me-to-a-random-string-in-production

# ----------------------------------------------------------
# OPTIONAL — Flask Debug Mode
# ----------------------------------------------------------
# Set to 1 ONLY for local development — NEVER in production.
# Debug mode exposes full stack traces to the browser.
# ----------------------------------------------------------
FLASK_DEBUG=0
